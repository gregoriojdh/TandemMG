<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema oscuro -->
    <style name="Base.Theme.TandemMG" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Colores principales (se mantienen igual en oscuro) -->
        <item name="colorPrimary">@color/coral</item>
        <item name="colorPrimaryDark">@color/coral_dark</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold_dark</item>

        <!-- Fondo y superficie oscuros -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>

        <!-- Texto sobre colores en modo oscuro -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>

    </style>

</resources>